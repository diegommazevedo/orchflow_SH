# Never bake secrets or local state into the Docker image
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Dev/test artifacts
.pytest_cache/
.coverage
htmlcov/
*.log
logs/

# Version control
.git/
.gitignore

# IDE
.vscode/
.idea/

# Local DB files
*.db
*.sqlite
