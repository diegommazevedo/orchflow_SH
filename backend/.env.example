# ── OrchFlow Backend — Variáveis de ambiente ──────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NÃO commite o .env real (adicione ao .gitignore)

# ── Banco de dados ────────────────────────────────────────────────────────────
# Local (Docker):
DATABASE_URL=postgresql://orchflow:orchflow@localhost:5432/orchflow
# Railway (substitua pela URL gerada pelo painel):
# DATABASE_URL=postgresql://postgres:senha@containers-us-west-xxx.railway.app:5432/railway

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-este-valor-em-producao

# Expiração do token em minutos (default: 10080 = 7 dias)
# TOKEN_EXPIRE_MINUTES=10080

# Sprint 5 (JWT + refresh + OAuth)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:5180
DISABLE_AUTH=false
ENVIRONMENT=development  # production em produção

# ── Groq (LLM) ───────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_sua_chave_aqui

# ── AI Token Manager — Sprint 7.5 ────────────────────────────────────────────
# Chaves NUNCA expostas ao frontend — somente variáveis de ambiente no backend
OPENAI_API_KEY=sk_sua_chave_openai_aqui
ANTHROPIC_API_KEY=sk-ant-sua_chave_anthropic_aqui

# ── CORS (produção) ───────────────────────────────────────────────────────────
# Lista de origens separadas por vírgula
# Local não precisa (já incluído no código)
ALLOWED_ORIGINS=https://seu-app.vercel.app
